{
  "name": "codewars-bot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm --prefix packages/backend run dev",
    "dev:frontend": "npm --prefix packages/frontend run dev",
    "test:backend": "npm --prefix packages/backend run test",
    "test:frontend": "npm --prefix packages/frontend run test",
    "test:shared": "npm --prefix packages/shared run test",
    "test:integration": "node test/index.js",
    "test:all": "npm run test:backend && npm run test:frontend && npm run test:shared && npm run test:integration"
  },
  "imports": {
    "#shared": "./packages/shared/index.js"
  }
}
